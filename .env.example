# Copy this file to .env and fill in real values for local development.
# In production (Portainer), set these as container environment variables instead.
# .env is gitignored — never commit real secrets.

# Required. Admin login password (minimum 8 characters).
ADMIN_PASSWORD=

# Required. Session cookie signing secret (minimum 16 characters, random).
# Generate one with PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
# Or with Node:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# Optional. Defaults to 3000.
PORT=3000

# Optional. Set to "production" for secure cookies (requires HTTPS).
# Leave unset or set to "development" for local testing over http://localhost.
NODE_ENV=development

# Optional. Override the secure-cookie flag explicitly.
# Defaults to true when NODE_ENV=production, false otherwise.
# Set to "false" if the server is reached over plain HTTP in production
# (e.g. before HTTPS is configured in front of the container) — otherwise
# the browser will not store the session cookie and every authenticated
# request will return 401.
# COOKIE_SECURE=false
